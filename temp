    <title>OtakuCloud | Anime Streaming</title>
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <nav class="navbar glass">
        <div class="nav-left">
            <h1 class="logo">Otaku<span class="accent">Cloud</span></h1>
            <ul class="nav-links">
                <li><a href="#" class="active">Home</a></li>
                <li><a href="#">Anime</a></li>
                <li><a href="#">Movies</a></li>
                <li><a href="#">Genres</a></li>
                <li><a href="#">My List</a></li>
            </ul>
        </div>
        <div class="nav-right">
            <div class="search-bar">
                <i class="fas fa-search"></i>
                <input type="text" placeholder="Search anime...">
            </div>
            <button class="btn-subscribe">Subscribe</button>
            <div class="avatar"></div>
        </div>
    </nav>

    <header class="hero" id="hero-slider">
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <div class="tags">
                <span class="rating">TV-MA</span>
                <span class="duration">24m</span>
                <span class="genre">Action • Fantasy • Shounen</span>
            </div>
            <h2 class="hero-title">Solo Leveling</h2>
            <p class="hero-desc">In a world where hunters with magical powers must battle deadly monsters to protect the human race from certain annihilation, a notoriously weak hunter named Sung Jinwoo finds himself in a seemingly endless struggle for survival.</p>
